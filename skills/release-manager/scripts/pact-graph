#!/usr/bin/env python3
"""Derive the service dependency graph from consumer-driven pact filenames and
detect drift against the GENERATED block in docs/release-manifest.yaml.

This is the deploy ORDERING authority only — the rate limiter that keeps a
consumer from going live ahead of a provider it depends on. Contract HEALTH
(staleness, sync gaps, and CI verification coverage) is /contract-check's job;
this script does not duplicate it.

Used by /release-status (read-only render) and /release-manager (gate +
reconcile).

Pact filename convention:  <consumer>-consumer-<provider>-provider.json
The ordering graph is built from synced provider pacts
(<provider>/(src/)test/resources/pacts/) so it is deterministic across machines
(target/ build output would churn the committed manifest diff).

Read-only by default. With --write it rewrites the GENERATED block in the
manifest (used by /release-manager's reconcile step).

No third-party deps (no pyyaml): the script only ever parses the
marker-delimited GENERATED block; humans own order.manual / order.suppress and
the skills read those directly.

Ships in agent-skills/shared (skills/release-manager/scripts/); projects invoke
it via a ./scripts/pact-graph symlink. The project root is found by walking up
from the working directory to the nearest .mgit.conf (same convention as
contract-check.sh) — the manifest itself stays project-local.
"""
import glob
import os
import re
import sys


def find_project_root():
    d = os.getcwd()
    while d != os.path.dirname(d):
        if os.path.isfile(os.path.join(d, ".mgit.conf")):
            return d
        d = os.path.dirname(d)
    sys.stderr.write("pact-graph: could not find .mgit.conf "
                     "(run from within the project)\n")
    sys.exit(1)


ROOT = find_project_root()
MANIFEST = os.path.join(ROOT, "docs", "release-manifest.yaml")

GEN_START = "    # >>> GENERATED by scripts/pact-graph — do not hand-edit (release-manager rewrites)"
GEN_END = "    # <<< END GENERATED"

PACT_RE = re.compile(r"([a-z0-9]+)-consumer-([a-z0-9]+)-provider\.json$")


def _scan(patterns):
    edges = set()
    for pat in patterns:
        for path in glob.glob(pat):
            m = PACT_RE.search(os.path.basename(path))
            if m and m.group(1) != m.group(2):
                edges.add((m.group(1), m.group(2)))
    return edges


def synced_edges():
    """Pacts synced into the provider's source tree — the deterministic graph."""
    return _scan([
        os.path.join(ROOT, "*", "test", "resources", "pacts", "*-consumer-*-provider.json"),
        os.path.join(ROOT, "*", "src", "test", "resources", "pacts", "*-consumer-*-provider.json"),
    ])


def graph_by_consumer(edges):
    g = {}
    for c, p in edges:
        g.setdefault(c, set()).add(p)
    return g


def render_derived(by_consumer):
    lines = []
    for c in sorted(by_consumer):
        provs = ",".join(sorted(by_consumer[c]))
        lines.append(f"    {c}: [{provs}]")
    return lines


def read_generated_block():
    """Parse the consumer: [providers] lines inside the GENERATED markers."""
    if not os.path.isfile(MANIFEST):
        return None, []
    lines = open(MANIFEST, encoding="utf-8").read().splitlines()
    inside = False
    edges = set()
    found = False
    for ln in lines:
        if ln.strip() == GEN_START.strip():
            inside = True
            found = True
            continue
        if ln.strip() == GEN_END.strip():
            inside = False
            continue
        if inside:
            m = re.match(r"\s*([a-z0-9]+):\s*\[([^\]]*)\]", ln)
            if m:
                c = m.group(1)
                for p in m.group(2).split(","):
                    p = p.strip()
                    if p:
                        edges.add((c, p))
    return (found, edges)


def write_generated_block(by_consumer):
    text = open(MANIFEST, encoding="utf-8").read()
    block = "\n".join([GEN_START] + render_derived(by_consumer) + [GEN_END])
    pat = re.compile(re.escape(GEN_START) + r".*?" + re.escape(GEN_END), re.DOTALL)
    if pat.search(text):
        text = pat.sub(block, text)
    else:
        sys.stderr.write("pact-graph: GENERATED markers not found in manifest; "
                         "add them under order.derived first.\n")
        return False
    open(MANIFEST, "w", encoding="utf-8").write(text)
    return True


def main():
    write = "--write" in sys.argv[1:]

    synced = synced_edges()
    # Synced-source-only so the committed ordering graph is deterministic across
    # machines (target/ build output is local and would churn the diff).
    by_consumer = graph_by_consumer(synced)

    if write:
        ok = write_generated_block(by_consumer)
        print("---WRITE---")
        print("ok" if ok else "failed")
        return

    # --- ordering graph ---
    print("---GRAPH---")
    for ln in render_derived(by_consumer):
        print(ln.strip())

    # --- drift vs manifest GENERATED block ---
    print("---DRIFT---")
    found, manifest_edges = read_generated_block()
    if not found:
        print("status: no-generated-block (run with --write to bootstrap)")
    else:
        new = synced - manifest_edges
        removed = manifest_edges - synced
        if not new and not removed:
            print("status: in-sync")
        else:
            for c, p in sorted(new):
                print(f"new: {c} -> {p}")
            for c, p in sorted(removed):
                print(f"removed: {c} -> {p}")
    print("# contract coverage moved to /contract-check coverage")


if __name__ == "__main__":
    main()
