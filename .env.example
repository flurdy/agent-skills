# Path to shared skills repo
SHARED_REPO=/path/to/agent-skills

# Path to optional private repo
PRIVATE_REPO=/path/to/agent-skills-private

# Portable shared skills root (Pi and Codex discover this natively)
SKILLS_DIR=$HOME/.agents/skills

# Claude Code compatibility aliases and old Codex cleanup root
CLAUDE_SKILLS_DIR=$HOME/.claude/skills
LEGACY_CODEX_SKILLS_DIR=$HOME/.codex/skills
